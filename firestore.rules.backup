rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow both authenticated users and anonymous users to read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow any authenticated user (including anonymous) to read public collections
    match /categories/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /trending/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /recommended/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /content/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /characters/{characterId} {
      allow read: if request.auth != null &&
                 (resource.data.isPublic == true ||
                  resource.data.creatorId == request.auth.uid);
      allow update: if request.auth != null &&
                   request.auth.uid == resource.data.creatorId;
      allow delete: if request.auth != null &&
                   request.auth.uid == resource.data.creatorId;
      allow create: if request.auth != null;
    }
    
    match /chatRooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      
      // Allow authenticated users to read and write messages in chat rooms
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == resource.data.senderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.senderId;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}