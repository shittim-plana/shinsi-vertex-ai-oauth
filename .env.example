# Firebase Configuration
# Replace these values with your own Firebase project details
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
# G-XXXXXXXXXX is a Google Analytics ID, not a VAPID key
# Replace this with your actual Web Push certificate key from Firebase console
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin credentials for seeding database
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_USER_ID=your-admin-user-id
ADMIN_USER_NAME=AdminUser

GEMINI_API_KEY=your-gemini-api-key

NOVELAI_API_KEY=your-novelai-api-key
NEXT_PUBLIC_NOVELAI_API_KEY=your-novelai-api-key

GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

NEXT_PUBLIC_GCLOUD_PROJECT_ID=your-gcloud-project-id
NEXT_PUBLIC_GOOGLE_APPLICATION_CREDENTIAL_JSON={
  "type": "service_account",
  "project_id": "your-gcloud-project-id",
  "private_key_id": "your-private-key-id",
  "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR-PRIVATE-KEY\n-----END PRIVATE KEY-----\n",
  "client_email": "service-account@your-gcloud-project-id.iam.gserviceaccount.com",
  "client_id": "123456789012345678901",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/service-account%40your-gcloud-project-id.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}

PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret
PATREON_REDIRECT_URI=https://your-domain.example.com/api/patreon/callback

STRIPE_SECRET_KEY=your-stripe-secret-key

FIREBASE_ADMIN_SDK_CONFIG='{
  "type": "service_account",
  "project_id": "your-firebase-project-id",
  "private_key_id": "your-private-key-id",
  "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR-PRIVATE-KEY\n-----END PRIVATE KEY-----\n",
  "client_email": "firebase-adminsdk@your-firebase-project-id.iam.gserviceaccount.com",
  "client_id": "123456789012345678901",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-firebase-project-id.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}'

NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_OPENAI_API_KEY=your-openai-api-key
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
ADMIN_BOOTSTRAP_TOKEN=your-admin-bootstrap-token

GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-api-key
GOOGLE_AI_STUDIO_API_KEYS=your-google-ai-studio-api-key-1,your-google-ai-studio-api-key-2
OPENROUTER_API_KEY=your-openrouter-api-key

# Memory rollup feature toggles (HYPA level-1 summaries)
# on: enable automatic HYPA rollups during chat; off: disable instantly
MEMORY_HYPA_ROLLUP=on
MEMORY_RETRIEVAL_MODE=cascaded
MEMORY_SUMMARY_K1=5
MEMORY_SUMMARY_K2=5
MEMORY_MIN_SCORE=0.2
MEMORY_ALPHA=0.5
MEMORY_WEIGHT_BETA=0.6
DECAY_HALFLIFE_HOURS=72
MAX_CONTEXT_TOKENS_FOR_MEMORY=1024
DEBUG_RAG=false
# === Summary pipeline defaults ===
# Client-side budget limits for /api/summarize payloads (in bytes)
SUMMARY_CLIENT_BODY_BUDGET_BYTES=524288
SUMMARY_CLIENT_HEADROOM_BYTES=8192

# Server-side limits for summarize route
SUMMARY_SERVER_MAX_INPUT_CHARS=12000
SUMMARY_SERVER_CHUNK_CHARS=6000
SUMMARY_SERVER_MAX_MESSAGES=100

# Backward compatibility: allow legacy SUPA prompt framing on client (default false)
SUMMARY_CLIENT_SUPA_PROMPT_ENABLED=false
